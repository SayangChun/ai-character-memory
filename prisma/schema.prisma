generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id                 Int          @id @default(autoincrement())
  name               String       @unique
  display_name       String
  avatar_emoji       String       @default("")
  persona            String       @default("")
  speaking_style     String       @default("")
  relationship_stage String       @default("初识")
  notes              String       @default("")
  created_at         DateTime     @default(now())
  updated_at         DateTime     @default(now()) @updatedAt

  memories           Memory[]
  sessions           SessionLog[]

  @@map("characters")
}

model Memory {
  id              Int       @id @default(autoincrement())
  character_id    Int
  content         String
  content_hash    String
  category        String    @default("fact")
  importance      Int       @default(3)
  tags            String    @default("[]")
  source_platform String    @default("manual")
  is_pinned       Boolean   @default(false)
  is_active       Boolean   @default(true)
  occurred_at     DateTime?
  expires_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  character       Character @relation(fields: [character_id], references: [id], onDelete: Cascade)

  @@unique([character_id, content_hash])
  @@index([character_id])
  @@index([content_hash])
  @@index([category])
  @@index([importance])
  @@index([is_pinned])
  @@index([is_active])
  @@map("memories")
}

model SessionLog {
  id           Int       @id @default(autoincrement())
  character_id Int
  platform     String    @default("other")
  title        String    @default("")
  summary      String    @default("")
  raw_excerpt  String    @default("")
  created_at   DateTime  @default(now())

  character    Character @relation(fields: [character_id], references: [id], onDelete: Cascade)

  @@index([character_id])
  @@map("session_logs")
}
