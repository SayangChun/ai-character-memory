{
  "version": 2,
  "env": {
    "DATABASE_URL": "file:/tmp/ai-character-memory.db"
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "dist/**",
          "app/static/**",
          "prisma/**",
          "node_modules/.prisma/client/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/static/(.*)", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}
